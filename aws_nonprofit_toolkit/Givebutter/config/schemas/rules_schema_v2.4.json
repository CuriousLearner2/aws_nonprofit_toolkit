{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nonprofit.org/schemas/rules_schema_v2.4.json",
  "title": "Donation Processor Rules v2.4",
  "description": "Validates rules.json for Claude DPA system",
  "type": "object",
  "required": [
    "version",
    "email_typos"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "email_typos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string",
            "format": "hostname"
          },
          "to": {
            "type": "string",
            "format": "hostname"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "name_case": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string"
          },
          "format": {
            "type": "string",
            "enum": [
              "title",
              "upper",
              "lower"
            ]
          }
        }
      }
    },
    "campaign_aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "alias",
          "canonical"
        ],
        "properties": {
          "alias": {
            "type": "string"
          },
          "canonical": {
            "type": "string"
          }
        }
      }
    },
    "pull_frequency": {
      "type": "object",
      "properties": {
        "givebutter_hours": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "additionalProperties": false
}